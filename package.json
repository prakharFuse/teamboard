{
  "name": "teamboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "node --watch dist/server/index.js",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "tsc -p server/tsconfig.build.json",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@okta/oidc-middleware": "^4.x",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-session": "^1.x",
    "passport": "^0.7.x"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.x",
    "@types/passport": "^1.x",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
